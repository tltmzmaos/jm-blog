---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PostListItem from '../components/PostListItem.astro';
import { shouldShowDrafts } from '../utils/env';
import { calculateReadingTime } from '../utils/readingTime.js';

const showDrafts = shouldShowDrafts();
const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter((post) => showDrafts || !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    ...post,
    readingTime: calculateReadingTime(post.body || '').text,
  }));

const INITIAL_COUNT = 10;
---

<BaseLayout
  title="Jongmin Lee"
  description="Notes on software engineering, lab automation, and applying AI in offline environments."
>
  <Header />

  <main class="main-content" id="main-content">
    <section class="posts-section" aria-label="Writing">
      <div class="posts" id="posts">
        {
          sortedPosts.map((post, i) => (
            <div class:list={['post-wrapper', { hidden: i >= INITIAL_COUNT }]}>
              <PostListItem
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                heroImage={post.data.heroImage}
                slug={post.slug}
                tags={post.data.tags}
                readingTime={post.readingTime}
              />
            </div>
          ))
        }

        {sortedPosts.length === 0 && <p class="empty">No posts yet.</p>}
      </div>

      {
        sortedPosts.length > INITIAL_COUNT && (
          <div class="load-more" id="load-sentinel">
            <span class="load-text">Scroll for more</span>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>

<noscript>
  <style>
    .post-wrapper.hidden {
      display: block !important;
    }
    .load-more {
      display: none !important;
    }
  </style>
</noscript>

<style>
  .main-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  /* ═══ Posts ═══ */
  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-wrapper.hidden {
    display: none;
  }

  .post-wrapper.reveal {
    animation: fadeIn 0.3s ease forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .load-more {
    text-align: center;
    padding: 2rem 0 1rem;
  }

  .load-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  .load-more.done {
    display: none;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem 0;
  }

  @media (max-width: 640px) {
    .main-content {
      padding: 2.5rem 1.25rem 3rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    const DIGIT_POOL = '0123456789';
    const ALPHA_POOL = 'ABCDEFGHJKLMNPQRSTUVWXYZ';

    function scramble(
      el: HTMLElement,
      finalText: string,
      opts: { duration?: number } = {}
    ) {
      const duration = opts.duration ?? 520;
      const chars = finalText.split('');
      const start = performance.now();

      const anyEl = el as HTMLElement & { _scrambleRaf?: number };
      if (anyEl._scrambleRaf) cancelAnimationFrame(anyEl._scrambleRaf);

      const step = (now: number) => {
        const t = Math.min((now - start) / duration, 1);
        let out = '';
        for (let i = 0; i < chars.length; i++) {
          const ch = chars[i];
          if (ch === ' ' || ch === '·' || ch === ',' || ch === '.') {
            out += ch;
            continue;
          }
          const threshold = (i / Math.max(chars.length - 1, 1)) * 0.6 + 0.18;
          if (t > threshold) {
            out += ch;
          } else {
            const pool = /\d/.test(ch) ? DIGIT_POOL : ALPHA_POOL;
            out += pool[Math.floor(Math.random() * pool.length)];
          }
        }
        el.textContent = out;
        if (t < 1) {
          anyEl._scrambleRaf = requestAnimationFrame(step);
        } else {
          el.textContent = finalText;
          anyEl._scrambleRaf = undefined;
        }
      };
      anyEl._scrambleRaf = requestAnimationFrame(step);
    }

    // Scramble visible post dates on load
    if (!reducedMotion) {
      const visibleDates = document.querySelectorAll<HTMLElement>(
        '.post-wrapper:not(.hidden) .date'
      );
      visibleDates.forEach((el, idx) => {
        const target = el.dataset.final || el.textContent || '';
        setTimeout(() => scramble(el, target), Math.min(idx * 55, 440));
      });
    }

    // Hover scramble on read-time
    const postLinks = document.querySelectorAll<HTMLElement>('.post-link');
    postLinks.forEach((link) => {
      const rt = link.querySelector<HTMLElement>('.read-time');
      if (!rt) return;
      const finalText = rt.dataset.final || '';
      link.addEventListener('mouseenter', () => {
        if (reducedMotion) {
          rt.textContent = finalText;
          return;
        }
        scramble(rt, finalText, { duration: 480 });
      });
    });

    // Lazy load-more
    const sentinel = document.getElementById('load-sentinel');
    if (!sentinel) return;

    const posts = document.querySelectorAll<HTMLElement>('.post-wrapper');
    const BATCH = 10;
    let shown = 0;

    posts.forEach((p) => {
      if (!p.classList.contains('hidden')) shown++;
    });

    if (shown >= posts.length) {
      sentinel.classList.add('done');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;

        let revealed = 0;
        const newlyRevealed: HTMLElement[] = [];
        for (let i = shown; i < posts.length && revealed < BATCH; i++) {
          posts[i].classList.remove('hidden');
          posts[i].classList.add('reveal');
          newlyRevealed.push(posts[i]);
          revealed++;
        }
        shown += revealed;

        // Scramble dates for newly revealed items
        if (!reducedMotion) {
          newlyRevealed.forEach((p, idx) => {
            const dateEl = p.querySelector<HTMLElement>('.date');
            if (!dateEl) return;
            const target = dateEl.dataset.final || dateEl.textContent || '';
            setTimeout(() => scramble(dateEl, target), idx * 45);
          });
        }

        if (shown >= posts.length) {
          sentinel.classList.add('done');
          observer.disconnect();
        }
      },
      { rootMargin: '200px' }
    );

    observer.observe(sentinel);

    document.addEventListener(
      'astro:before-swap',
      () => observer.disconnect(),
      { once: true }
    );
  });
</script>
