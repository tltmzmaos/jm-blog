---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { shouldShowDrafts } from '../../utils/env';

const showDrafts = shouldShowDrafts();
const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter((post) => showDrafts || !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tagMap = new Map<string, { count: number; latest: Date }>();
for (const post of publishedPosts) {
  for (const tag of post.data.tags) {
    const entry = tagMap.get(tag);
    if (!entry) {
      tagMap.set(tag, { count: 1, latest: post.data.pubDate });
    } else {
      entry.count += 1;
      if (post.data.pubDate.valueOf() > entry.latest.valueOf()) {
        entry.latest = post.data.pubDate;
      }
    }
  }
}

const sortedTags = [...tagMap.entries()]
  .sort(([a, ai], [b, bi]) => {
    if (ai.count !== bi.count) return bi.count - ai.count;
    return a.localeCompare(b);
  })
  .map(([tag, { count, latest }]) => ({ tag, count, latest }));

const mainTags = sortedTags.filter((t) => t.count >= 2);
const singletons = sortedTags.filter((t) => t.count === 1);

const formatLatest = (d: Date) =>
  `last ${new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
  }).format(d)}`;

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Tags — Jongmin Lee"
  description="Topics that come up most often in my writing, sorted by post count."
>
  <Header />

  <main class="main-content" id="main-content">
    <header class="page-header">
      <h1>Tags</h1>
      <p class="page-lead">Sorted by post count. Most active topics first.</p>
    </header>

    <div class="search-box">
      <svg
        class="search-icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        type="text"
        id="tag-search"
        placeholder="Filter tags..."
        autocomplete="off"
      />
      <kbd class="shortcut">/</kbd>
    </div>

    <ul class="tag-list" id="tag-list">
      {
        mainTags.map(({ tag, count, latest }) => {
          const dateText = formatLatest(latest);
          return (
            <li class="tag-item" data-tag={tag.toLowerCase()}>
              <a href={`${baseUrl}tags/${encodeURIComponent(tag)}`} class="tag">
                <span class="tag-name">{tag}</span>
                <span class="tag-meta">
                  <span class="tag-count" data-count={count}>
                    {count}
                  </span>
                  <span class="dot" aria-hidden="true">
                    ·
                  </span>
                  <span class="tag-latest" data-final={dateText}>
                    {dateText}
                  </span>
                </span>
              </a>
            </li>
          );
        })
      }
      {
        singletons.map(({ tag, count, latest }) => {
          const dateText = formatLatest(latest);
          return (
            <li
              class="tag-item is-singleton"
              data-tag={tag.toLowerCase()}
              hidden
            >
              <a href={`${baseUrl}tags/${encodeURIComponent(tag)}`} class="tag">
                <span class="tag-name">{tag}</span>
                <span class="tag-meta">
                  <span class="tag-count" data-count={count}>
                    {count}
                  </span>
                  <span class="dot" aria-hidden="true">
                    ·
                  </span>
                  <span class="tag-latest" data-final={dateText}>
                    {dateText}
                  </span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>

    {
      singletons.length > 0 && (
        <div class="show-more">
          <button
            id="toggle-singletons"
            class="toggle-link"
            type="button"
            data-expanded="false"
            data-count={singletons.length}
          >
            <span class="toggle-label">
              Show {singletons.length} single-post tags
            </span>
            <svg
              class="chevron"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </button>
        </div>
      )
    }
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const list = document.getElementById('tag-list');
    const searchInput = document.getElementById(
      'tag-search'
    ) as HTMLInputElement | null;
    const toggleBtn = document.getElementById(
      'toggle-singletons'
    ) as HTMLButtonElement | null;
    const items = list?.querySelectorAll<HTMLElement>('.tag-item');
    const singletons = list?.querySelectorAll<HTMLElement>(
      '.tag-item.is-singleton'
    );
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    const DIGIT_POOL = '0123456789';
    const ALPHA_POOL = 'ABCDEFGHJKLMNPQRSTUVWXYZ';

    function scramble(
      el: HTMLElement,
      finalText: string,
      opts: { duration?: number; digitsOnly?: boolean } = {}
    ) {
      const duration = opts.duration ?? 600;
      const chars = finalText.split('');
      const start = performance.now();

      const anyEl = el as HTMLElement & { _scrambleRaf?: number };
      if (anyEl._scrambleRaf) cancelAnimationFrame(anyEl._scrambleRaf);

      const step = (now: number) => {
        const t = Math.min((now - start) / duration, 1);
        let out = '';
        for (let i = 0; i < chars.length; i++) {
          const ch = chars[i];
          if (ch === ' ' || ch === '·' || ch === '.') {
            out += ch;
            continue;
          }
          const threshold = (i / Math.max(chars.length - 1, 1)) * 0.6 + 0.18;
          if (t > threshold) {
            out += ch;
          } else {
            const pool = opts.digitsOnly
              ? DIGIT_POOL
              : /\d/.test(ch)
                ? DIGIT_POOL
                : ALPHA_POOL;
            out += pool[Math.floor(Math.random() * pool.length)];
          }
        }
        el.textContent = out;
        if (t < 1) {
          anyEl._scrambleRaf = requestAnimationFrame(step);
        } else {
          el.textContent = finalText;
          anyEl._scrambleRaf = undefined;
        }
      };
      anyEl._scrambleRaf = requestAnimationFrame(step);
    }

    function scrambleVisibleMeta() {
      if (reducedMotion) return;
      const counts = list?.querySelectorAll<HTMLElement>(
        '.tag-item:not([hidden]) .tag-count'
      );
      counts?.forEach((el, idx) => {
        const target = el.dataset.count || '0';
        const delay = Math.min(idx * 18, 220);
        el.textContent = '';
        setTimeout(
          () =>
            scramble(el, target, {
              duration: 420 + target.length * 80,
              digitsOnly: true,
            }),
          delay
        );
      });

      const dates = list?.querySelectorAll<HTMLElement>(
        '.tag-item:not([hidden]) .tag-latest'
      );
      dates?.forEach((el, idx) => {
        const target = el.dataset.final || el.textContent || '';
        const delay = Math.min(idx * 20, 280);
        setTimeout(() => scramble(el, target, { duration: 520 }), delay);
      });
    }

    scrambleVisibleMeta();

    toggleBtn?.addEventListener('click', () => {
      const expanded = toggleBtn.dataset.expanded === 'true';
      const next = !expanded;
      toggleBtn.dataset.expanded = String(next);

      singletons?.forEach((el) => {
        if (next) {
          el.removeAttribute('hidden');
        } else {
          el.setAttribute('hidden', '');
        }
      });

      const n = toggleBtn.dataset.count || '0';
      const label = toggleBtn.querySelector('.toggle-label');
      if (label) {
        label.textContent = next
          ? 'Hide single-post tags'
          : `Show ${n} single-post tags`;
      }

      if (next) {
        // Scramble the newly revealed singletons' meta
        if (!reducedMotion) {
          singletons?.forEach((el, idx) => {
            const countEl = el.querySelector<HTMLElement>('.tag-count');
            const dateEl = el.querySelector<HTMLElement>('.tag-latest');
            const delay = Math.min(idx * 18, 220);
            if (countEl) {
              const target = countEl.dataset.count || '0';
              countEl.textContent = '';
              setTimeout(
                () =>
                  scramble(countEl, target, {
                    duration: 360,
                    digitsOnly: true,
                  }),
                delay
              );
            }
            if (dateEl) {
              const target = dateEl.dataset.final || dateEl.textContent || '';
              setTimeout(
                () => scramble(dateEl, target, { duration: 460 }),
                delay + 40
              );
            }
          });
        }
      }
    });

    if (!list || !items?.length) return;

    const filterTags = (q: string) => {
      const query = q.toLowerCase().trim();
      const isExpanded = toggleBtn?.dataset.expanded === 'true';
      for (const el of items) {
        const tag = el.dataset.tag || '';
        const matchesQuery = query.length === 0 || tag.includes(query);
        const isSingleton = el.classList.contains('is-singleton');

        if (query.length > 0) {
          // While searching, reveal singletons that match
          el.classList.toggle('filtered', !matchesQuery);
          if (isSingleton && matchesQuery) el.removeAttribute('hidden');
        } else {
          el.classList.remove('filtered');
          if (isSingleton && !isExpanded) el.setAttribute('hidden', '');
        }
      }
    };

    searchInput?.addEventListener('input', () => {
      filterTags(searchInput.value);
    });

    const onKey = (e: KeyboardEvent) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput?.focus();
      }
      if (e.key === 'Escape' && searchInput) {
        searchInput.value = '';
        searchInput.blur();
        filterTags('');
      }
    };
    document.addEventListener('keydown', onKey);

    document.addEventListener(
      'astro:before-swap',
      () => document.removeEventListener('keydown', onKey),
      { once: true }
    );
  });
</script>

<style>
  .main-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 2.625rem);
    font-weight: 500;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 0.875rem;
    line-height: 1.15;
  }

  .page-lead {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 58ch;
  }

  /* ═══ Search ═══ */
  .search-box {
    position: relative;
    margin-bottom: 2rem;
  }

  .search-icon {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
    transition: color 0.15s ease;
  }

  .search-box:has(#tag-search:focus) .search-icon {
    color: var(--color-accent);
  }

  #tag-search {
    width: 100%;
    padding: 0.5rem 2rem 0.5rem 1.625rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--color-text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border-light);
    border-radius: 0;
    outline: none;
    transition: border-color 0.15s ease;
  }

  #tag-search::placeholder {
    color: var(--color-text-muted);
  }

  #tag-search:focus {
    border-color: var(--color-accent);
  }

  .shortcut {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.125rem 0.375rem;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border-radius: 4px;
    pointer-events: none;
    transition: opacity 0.15s;
  }

  #tag-search:focus ~ .shortcut {
    opacity: 0;
  }

  /* ═══ Tag list ═══ */
  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .tag-item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .tag-item.filtered {
    display: none;
  }

  .tag {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 1rem;
    padding: 0.625rem 0;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .tag:hover {
    color: var(--color-accent);
  }

  .tag-name {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.3;
  }

  .tag-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .tag-meta .dot {
    color: var(--color-border);
  }

  .tag-count {
    min-width: 1.5ch;
    text-align: right;
  }

  .tag:hover .tag-meta {
    color: var(--color-accent);
  }

  .tag:hover .tag-meta .dot {
    color: color-mix(in srgb, var(--color-accent) 50%, transparent);
  }

  /* ═══ Show more ═══ */
  .show-more {
    margin-top: 1.75rem;
    display: flex;
    justify-content: center;
  }

  .toggle-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.5rem 0.875rem;
    cursor: pointer;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .toggle-link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .toggle-link .chevron {
    transition: transform 0.2s ease;
  }

  .toggle-link[data-expanded='true'] .chevron {
    transform: rotate(180deg);
  }

  @media (max-width: 640px) {
    .main-content {
      padding: 2.5rem 1.25rem 3rem;
    }
  }
</style>
