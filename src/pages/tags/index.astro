---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { shouldShowDrafts } from '../../utils/env';

const showDrafts = shouldShowDrafts();
const allPosts = await getCollection('blog');
const publishedPosts = allPosts
  .filter((post) => showDrafts || !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Gather count + latest post date per tag
const tagMap = new Map<string, { count: number; latest: Date }>();
for (const post of publishedPosts) {
  for (const tag of post.data.tags) {
    const entry = tagMap.get(tag);
    if (!entry) {
      tagMap.set(tag, { count: 1, latest: post.data.pubDate });
    } else {
      entry.count += 1;
      if (post.data.pubDate.valueOf() > entry.latest.valueOf()) {
        entry.latest = post.data.pubDate;
      }
    }
  }
}

const sortedTags = [...tagMap.entries()]
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([tag, { count, latest }]) => ({ tag, count, latest }));

const topTags = [...sortedTags].sort((a, b) => b.count - a.count).slice(0, 3);

const formatShort = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short' }).format(
    d
  );

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title="Tags — Jongmin Lee" description="Browse all tags.">
  <Header />

  <main class="main-content" id="main-content">
    <header class="page-header">
      <p class="eyebrow">— Index</p>
      <h1>Tags</h1>
      {
        topTags.length > 0 && (
          <p class="top-tags">
            Most written about ·{' '}
            {topTags.map((t, i) => (
              <>
                {i > 0 && <span class="dot">, </span>}
                <a
                  href={`${baseUrl}tags/${encodeURIComponent(t.tag)}`}
                  class="top-tag"
                >
                  {t.tag}
                </a>
              </>
            ))}
            .
          </p>
        )
      }
    </header>

    <div class="search-box">
      <svg
        class="search-icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        type="text"
        id="tag-search"
        placeholder="Filter tags..."
        autocomplete="off"
      />
      <kbd class="shortcut">/</kbd>
    </div>

    <ul class="tag-list" id="tag-list">
      {
        sortedTags.map(({ tag, count, latest }) => {
          const dateText = `latest · ${formatShort(latest)}`;
          return (
            <li class="tag-item" data-tag={tag.toLowerCase()}>
              <a href={`${baseUrl}tags/${encodeURIComponent(tag)}`} class="tag">
                <span class="tag-name">{tag}</span>
                <span class="tag-count" data-count={count}>
                  {count}
                </span>
                <span class="tag-latest" data-final={dateText}>
                  {dateText}
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </main>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const list = document.getElementById('tag-list');
    const searchInput = document.getElementById(
      'tag-search'
    ) as HTMLInputElement | null;
    const items = list?.querySelectorAll<HTMLElement>('.tag-item');
    const reducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    const DIGIT_POOL = '0123456789';
    const ALPHA_POOL = 'ABCDEFGHJKLMNPQRSTUVWXYZ';

    function scramble(
      el: HTMLElement,
      finalText: string,
      opts: { duration?: number; digitsOnly?: boolean } = {}
    ) {
      const duration = opts.duration ?? 600;
      const chars = finalText.split('');
      const start = performance.now();

      // Cancel any in-flight scramble
      const anyEl = el as HTMLElement & { _scrambleRaf?: number };
      if (anyEl._scrambleRaf) cancelAnimationFrame(anyEl._scrambleRaf);

      const step = (now: number) => {
        const t = Math.min((now - start) / duration, 1);
        let out = '';
        for (let i = 0; i < chars.length; i++) {
          const ch = chars[i];
          if (ch === ' ' || ch === '·' || ch === '.') {
            out += ch;
            continue;
          }
          const threshold = (i / Math.max(chars.length - 1, 1)) * 0.6 + 0.18;
          if (t > threshold) {
            out += ch;
          } else {
            const pool = opts.digitsOnly
              ? DIGIT_POOL
              : /\d/.test(ch)
                ? DIGIT_POOL
                : ALPHA_POOL;
            out += pool[Math.floor(Math.random() * pool.length)];
          }
        }
        el.textContent = out;
        if (t < 1) {
          anyEl._scrambleRaf = requestAnimationFrame(step);
        } else {
          el.textContent = finalText;
          anyEl._scrambleRaf = undefined;
        }
      };
      anyEl._scrambleRaf = requestAnimationFrame(step);
    }

    // Count scramble on load
    const counts = list?.querySelectorAll<HTMLElement>('.tag-count');
    if (counts?.length && !reducedMotion) {
      counts.forEach((el, idx) => {
        const target = el.dataset.count || '0';
        const delay = Math.min(idx * 18, 220);
        el.textContent = '';
        setTimeout(
          () =>
            scramble(el, target, {
              duration: 420 + target.length * 80,
              digitsOnly: true,
            }),
          delay
        );
      });
    }

    // Hover scramble on latest date
    const tags = list?.querySelectorAll<HTMLElement>('.tag');
    tags?.forEach((tagEl) => {
      const latestEl = tagEl.querySelector<HTMLElement>('.tag-latest');
      if (!latestEl) return;
      const finalText = latestEl.dataset.final || latestEl.textContent || '';
      tagEl.addEventListener('mouseenter', () => {
        if (reducedMotion) {
          latestEl.textContent = finalText;
          return;
        }
        scramble(latestEl, finalText, { duration: 560 });
      });
    });

    if (!list || !items?.length) return;

    const filterTags = (q: string) => {
      const query = q.toLowerCase().trim();
      for (const el of items) {
        const tag = el.dataset.tag || '';
        el.classList.toggle(
          'filtered',
          query.length > 0 && !tag.includes(query)
        );
      }
    };

    searchInput?.addEventListener('input', () => {
      filterTags(searchInput.value);
    });

    const onKey = (e: KeyboardEvent) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput?.focus();
      }
      if (e.key === 'Escape' && searchInput) {
        searchInput.value = '';
        searchInput.blur();
        filterTags('');
      }
    };
    document.addEventListener('keydown', onKey);

    document.addEventListener(
      'astro:before-swap',
      () => document.removeEventListener('keydown', onKey),
      { once: true }
    );
  });
</script>

<style>
  .main-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  /* ═══ Header ═══ */
  .page-header {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 2.625rem);
    font-weight: 500;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    line-height: 1.15;
  }

  .top-tags {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 54ch;
  }

  .top-tag {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1px;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }

  .top-tag:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .dot {
    color: var(--color-text-secondary);
  }

  /* ═══ Search ═══ */
  .search-box {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .search-icon {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
    transition: color 0.15s ease;
  }

  .search-box:has(#tag-search:focus) .search-icon {
    color: var(--color-accent);
  }

  #tag-search {
    width: 100%;
    padding: 0.5rem 2rem 0.5rem 1.625rem;
    font-size: 0.875rem;
    font-family: inherit;
    color: var(--color-text);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border-light);
    border-radius: 0;
    outline: none;
    transition: border-color 0.15s ease;
  }

  #tag-search::placeholder {
    color: var(--color-text-muted);
  }

  #tag-search:focus {
    border-color: var(--color-accent);
  }

  .shortcut {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.125rem 0.375rem;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    border-radius: 4px;
    pointer-events: none;
    transition: opacity 0.15s;
  }

  #tag-search:focus ~ .shortcut {
    opacity: 0;
  }

  /* ═══ Tag list ═══ */
  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0 2rem;
  }

  .tag-item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .tag-item.filtered {
    display: none;
  }

  .tag {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .tag:hover {
    color: var(--color-accent);
  }

  .tag-name {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    grid-column: 1;
    grid-row: 1;
  }

  .tag-count {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    min-width: 1.5ch;
    text-align: right;
  }

  .tag-latest {
    grid-column: 1 / -1;
    grid-row: 2;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transform: translateY(-3px);
    transition:
      opacity 0.2s ease,
      max-height 0.25s ease,
      transform 0.25s ease;
  }

  .tag:hover .tag-latest {
    opacity: 1;
    max-height: 1.6em;
    transform: translateY(0);
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .main-content {
      padding: 2.5rem 1.25rem 3rem;
    }

    .tag-list {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-latest {
      transition: none;
    }
  }
</style>
