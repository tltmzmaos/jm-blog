---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import PostListItem from '../../components/PostListItem.astro';
import { shouldShowDrafts } from '../../utils/env';

export async function getStaticPaths() {
  const showDrafts = shouldShowDrafts();
  const allPosts = await getCollection('blog');
  const publishedPosts = allPosts.filter(
    (post) => showDrafts || !post.data.draft
  );

  const uniqueTags = [
    ...new Set(publishedPosts.flatMap((post) => post.data.tags)),
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts = publishedPosts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    const relatedTagCounts = filteredPosts.reduce(
      (acc, post) => {
        post.data.tags.forEach((t) => {
          if (t !== tag) acc[t] = (acc[t] || 0) + 1;
        });
        return acc;
      },
      {} as Record<string, number>
    );

    const relatedTags = Object.entries(relatedTagCounts)
      .sort(([, a], [, b]) => b - a)
      .slice(0, 8)
      .map(([t]) => t);

    return {
      params: { tag },
      props: { posts: filteredPosts, relatedTags },
    };
  });
}

const { tag } = Astro.params;
const { posts, relatedTags } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={`${tag} — Jongmin Lee`} description={`Posts tagged ${tag}.`}>
  <Header />

  <main class="main-content" id="main-content">
    <header class="page-header">
      <p class="eyebrow">— Tag</p>
      <h1>{tag}</h1>
      <p class="count">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'}
      </p>
      <a href={`${baseUrl}tags`} class="back-link">← All tags</a>
    </header>

    <section class="posts" aria-label={`Posts tagged ${tag}`}>
      {
        posts.map((post) => (
          <PostListItem
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            heroImage={post.data.heroImage}
            slug={post.slug}
            tags={post.data.tags}
          />
        ))
      }

      {posts.length === 0 && <p class="empty">No posts found with this tag.</p>}
    </section>

    {
      relatedTags.length > 0 && (
        <section class="related-tags">
          <h2 class="section-label">Related</h2>
          <p class="related-list">
            {relatedTags.map((t, i) => (
              <>
                {i > 0 && <span class="dot"> · </span>}
                <a
                  href={`${baseUrl}tags/${encodeURIComponent(t)}`}
                  class="related-tag"
                >
                  {t}
                </a>
              </>
            ))}
          </p>
        </section>
      )
    }
  </main>
</BaseLayout>

<style>
  .main-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 4rem;
  }

  /* ═══ Header ═══ */
  .page-header {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .page-header h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4.5vw, 2.625rem);
    font-weight: 500;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 0.5rem;
    line-height: 1.15;
  }

  .count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  /* ═══ Posts ═══ */
  .posts {
    display: flex;
    flex-direction: column;
  }

  .empty {
    text-align: center;
    color: var(--color-text-muted);
    padding: 3rem 0;
  }

  /* ═══ Related ═══ */
  .related-tags {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-light);
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .related-list {
    margin: 0;
    line-height: 1.8;
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
  }

  .related-tag {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .related-tag:hover {
    color: var(--color-accent);
  }

  .dot {
    color: var(--color-border);
  }

  @media (max-width: 640px) {
    .main-content {
      padding: 2.5rem 1.25rem 3rem;
    }
  }
</style>
