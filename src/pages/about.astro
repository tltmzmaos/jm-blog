---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

interface TimelineEntry {
  title: string;
  location: string;
  desc?: string;
}

interface TimelineGroup {
  year: string;
  entries: TimelineEntry[];
}

const timeline: TimelineGroup[] = [
  {
    year: '2025',
    entries: [
      {
        title: 'Software Engineer, Lab Automation',
        location: 'Bay Area',
        desc: 'Orchestration services for scheduling and instrument coordination across automation equipment.',
      },
    ],
  },
  {
    year: '2024',
    entries: [
      {
        title: 'M.S. Computer Science',
        location: 'Georgia Tech, OMSCS',
        desc: 'AI and machine learning focus. In progress.',
      },
    ],
  },
  {
    year: '2021',
    entries: [
      {
        title: 'Software Developer, Automotive',
        location: 'Irvine',
        desc: 'API integrations, data processing, and reconciliation across distributed systems.',
      },
      {
        title: 'B.S. Computer Science',
        location: 'UC Irvine',
        desc: 'Specialization in Information.',
      },
    ],
  },
];
---

<BaseLayout
  title="About — Jongmin Lee"
  description="A place where I organize and share what I learn, build, and think about — with a little help from AI."
>
  <Header />

  <main class="about-page" id="main-content">
    <header class="intro-block">
      <div class="identity">
        <h1 class="name">Jongmin Lee</h1>
        <p class="tagline">Software Engineer · Bay Area</p>
        <ul class="contacts" aria-label="Contact">
          <li>
            <a href="mailto:tltmzmaos@gmail.com" aria-label="Email">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2.5" y="4.5" width="19" height="15" rx="2.5"></rect>
                <path d="m3 7 9 6 9-6"></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/jml1228"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href="https://github.com/tltmzmaos"
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
            >
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <div class="prose">
        <p>
          I work in lab automation within the life sciences industry. My
          day-to-day is about how scientific instruments talk to each other and
          how the system tracks what every machine is doing. Before this I was
          in automotive, mostly on data movement between systems — so a lot of
          what I'm doing now is new territory.
        </p>
        <p>
          I think a lot about how AI tools are reshaping software work. I'm
          experiencing that shift in my own job, and a good chunk of my
          thinking goes into how to actually use these tools well.
        </p>
        <p>
          I'm also studying AI through Georgia Tech's OMSCS program. Going
          through a graduate program now feels different from my undergrad
          years — part of what I'm paying attention to is how education itself
          is changing along with everything else.
        </p>
        <p>
          This blog is where I share those questions, thoughts, and experiences
          as they come up.
        </p>
      </div>

    </header>

    <section class="section">
      <h2 class="section-label">Background</h2>
      <ol class="timeline">
        {
          timeline.map((group) => (
            <li class="timeline-group">
              <span class="timeline-year">{group.year}</span>
              <div class="timeline-entries">
                {group.entries.map((entry) => (
                  <div class="timeline-entry">
                    <h3 class="timeline-title">{entry.title}</h3>
                    <p class="timeline-meta">{entry.location}</p>
                    {entry.desc && <p class="timeline-desc">{entry.desc}</p>}
                  </div>
                ))}
              </div>
            </li>
          ))
        }
      </ol>
    </section>

  </main>
</BaseLayout>

<style>
  .about-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }

  /* ═══ Intro ═══ */
  .intro-block {
    padding-bottom: 3rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .name {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 2.875rem);
    font-weight: 500;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin: 0;
  }

  .prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 58ch;
    margin: 0 auto;
    text-align: center;
  }

  .prose p {
    margin: 0 0 1.1rem;
  }

  .prose p:last-child {
    margin-bottom: 0;
  }

  /* ═══ Contacts ═══ */
  .contacts {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    justify-content: center;
  }

  .contacts a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 50%;
    transition: color 0.15s ease;
  }

  .contacts a:hover {
    color: var(--color-accent);
  }

  .contacts svg {
    display: block;
  }

  /* ═══ Sections ═══ */
  .section {
    margin-bottom: 3rem;
  }

  .section:last-child {
    margin-bottom: 0;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
  }

  /* ═══ Timeline ═══ */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-group {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1.25rem;
    padding: 1.375rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .timeline-group:last-child {
    border-bottom: none;
  }

  .timeline-year {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    padding-top: 0.25rem;
  }

  .timeline-entries {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
    min-width: 0;
  }

  .timeline-entry {
    min-width: 0;
  }

  .timeline-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--color-text);
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .timeline-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }

  .timeline-desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    max-width: 54ch;
  }

  @media (max-width: 640px) {
    .about-page {
      padding: 2.5rem 1.25rem 3rem;
    }

    .intro-block {
      padding-bottom: 2rem;
      margin-bottom: 2rem;
    }

    .contacts {
      gap: 1.25rem;
      flex-wrap: wrap;
    }

    .timeline-group {
      grid-template-columns: 56px 1fr;
      gap: 1rem;
    }
  }
</style>
