---
import { type CollectionEntry, getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { getSeriesInfo } from '../../utils/seriesPosts';
import { shouldShowDrafts } from '../../utils/env';

export async function getStaticPaths() {
  const showDrafts = shouldShowDrafts();
  const posts = await getCollection('blog');
  const visible = posts.filter((post) => showDrafts || !post.data.draft);
  return visible.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await post.render();

// Build the visible-post universe once and reuse for nav / related / series
const allPosts = await getCollection('blog');
const visiblePosts = allPosts.filter(
  (p) => shouldShowDrafts() || !p.data.draft
);
const sortedPosts = visiblePosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);

const prevPost =
  currentIndex < sortedPosts.length - 1
    ? {
        slug: sortedPosts[currentIndex + 1].slug,
        title: sortedPosts[currentIndex + 1].data.title,
        description: sortedPosts[currentIndex + 1].data.description,
      }
    : undefined;

const nextPost =
  currentIndex > 0
    ? {
        slug: sortedPosts[currentIndex - 1].slug,
        title: sortedPosts[currentIndex - 1].data.title,
        description: sortedPosts[currentIndex - 1].data.description,
      }
    : undefined;

// Find related posts (tag-based)
const relatedPosts = getRelatedPosts(post, visiblePosts, 3);

// Detect series membership
const seriesInfo = getSeriesInfo(post, visiblePosts);
---

<PostLayout
  frontmatter={post.data}
  headings={headings}
  prevPost={prevPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
  seriesInfo={seriesInfo}
  content={post.body}
  slug={post.slug}
>
  <Content />
</PostLayout>
