---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Not Found — Jongmin Lee"
  description="This page doesn't exist."
>
  <Header />
  <main class="not-found" id="main-content">
    <h1 class="title">This page got lost.</h1>
    <p class="lede">
      The address you followed doesn't lead anywhere — at least not here. The
      post may have moved, or the link might be a typo.
    </p>
    <nav class="links" aria-label="Recovery">
      <a href={baseUrl} class="link">Back to home</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href={`${baseUrl}tags`} class="link">Browse tags</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href={`${baseUrl}series`} class="link">Series</a>
    </nav>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 2.625rem);
    font-weight: 500;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.15;
    margin: 0 0 1.25rem;
  }

  .lede {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 2rem;
    max-width: 56ch;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }

  .link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .link:hover {
    color: var(--color-accent);
  }

  .dot {
    color: var(--color-border);
  }

  @media (max-width: 640px) {
    .not-found {
      padding: 3.5rem 1.25rem 3rem;
    }
  }
</style>
