---
export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  slug: string;
  tags?: string[];
  readingTime?: string;
}

const {
  title,
  description,
  pubDate,
  slug,
  tags = [],
  readingTime,
} = Astro.props;
const MAX_VISIBLE_TAGS = 3;
const visibleTags = tags.slice(0, MAX_VISIBLE_TAGS);
const remainingCount = tags.length - MAX_VISIBLE_TAGS;

const baseUrl = import.meta.env.BASE_URL;
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(pubDate);
---

<article class="post-item">
  <a href={`${baseUrl}posts/${slug}`} class="post-link">
    <div class="meta">
      <time
        class="date"
        datetime={pubDate.toISOString()}
        data-final={formattedDate}>{formattedDate}</time
      >
      {
        readingTime && (
          <span class="read-time" data-final={`· ${readingTime}`} />
        )
      }
    </div>
    <h3 class="title">{title}</h3>
    <p class="description">{description}</p>

    {
      tags.length > 0 && (
        <div class="tags">
          {visibleTags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
          {remainingCount > 0 && (
            <span class="tag tag-more">+{remainingCount}</span>
          )}
        </div>
      )
    }
  </a>
</article>

<style>
  .post-item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .post-link:hover {
    opacity: 0.72;
  }

  .post-link:hover .title {
    color: var(--color-accent);
  }

  .meta {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }

  .read-time {
    color: var(--color-accent);
    opacity: 0;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .post-link:hover .read-time {
    opacity: 1;
  }

  .title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    font-variation-settings: 'opsz' 48;
    letter-spacing: -0.01em;
    color: var(--color-text);
    line-height: 1.25;
    margin: 0 0 0.5rem;
    transition: color 0.15s ease;
  }

  .description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .tag-more {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-link {
      padding: 1.25rem 0;
    }

    .title {
      font-size: 1.1875rem;
    }
  }
</style>
